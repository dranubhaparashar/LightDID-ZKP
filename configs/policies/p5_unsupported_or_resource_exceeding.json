{
  "policy_id": "P5",
  "name": "Unsupported or resource-exceeding request",
  "semantics": "predicate_hidden_attributes",
  "revealed_attributes": [
    "membership"
  ],
  "hidden_attributes": [
    "age",
    "date_of_birth",
    "address",
    "credential_id"
  ],
  "predicates": [
    {
      "claim": "age",
      "op": ">=",
      "value": 18,
      "credential_backed": true,
      "issuer_certified_as_signed_claim": false
    }
  ],
  "unlinkability_required": true,
  "min_privacy_level": 3,
  "status_required": true,
  "nonce": "nonce-p5-demo",
  "domain": "verifier.example",
  "resource_budget": {
    "attributes": 64,
    "max_prove_ms": 100,
    "max_verify_ms": 100,
    "max_vp_bytes": 5000,
    "max_rss_mb": 180
  },
  "notes": "CAPS-ZK must reject rather than downgrade to a lower-cost but invalid backend."
}