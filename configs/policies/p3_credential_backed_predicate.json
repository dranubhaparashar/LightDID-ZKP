{
  "policy_id": "P3",
  "name": "Credential-backed age predicate",
  "semantics": "credential_backed_predicate",
  "revealed_attributes": [
    "membership"
  ],
  "hidden_attributes": [
    "date_of_birth",
    "age"
  ],
  "predicates": [
    {
      "claim": "age",
      "op": ">=",
      "value": 18,
      "credential_backed": true,
      "issuer_certified_as_signed_claim": false
    }
  ],
  "unlinkability_required": true,
  "min_privacy_level": 3,
  "status_required": false,
  "nonce": "nonce-p3-demo",
  "domain": "verifier.example",
  "resource_budget": {
    "attributes": 16,
    "max_prove_ms": 500,
    "max_verify_ms": 300,
    "max_vp_bytes": 50000,
    "max_rss_mb": 400
  },
  "notes": "AnonCreds is required because BBS cannot safely replace hidden credential-backed predicates."
}